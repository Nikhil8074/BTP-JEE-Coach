generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  topics    Topic[]
  createdAt DateTime @default(now())
}

model Topic {
  id        String     @id @default(cuid())
  name      String
  subjectId String
  subject   Subject    @relation(fields: [subjectId], references: [id])
  subtopics Subtopic[]
  questions Question[]
  createdAt DateTime   @default(now())

  @@unique([name, subjectId])
}

model Subtopic {
  id        String     @id @default(cuid())
  name      String
  topicId   String
  topic     Topic      @relation(fields: [topicId], references: [id])
  questions Question[]
  createdAt DateTime   @default(now())

  @@unique([name, topicId])
}

model Question {
  id            String       @id @default(cuid())
  type          String       // MCQ, NUMERICAL
  difficulty    String       // EASY, MEDIUM, HARD
  questionText  String
  options       String?      // JSON string of options ["A", "B", "C", "D"]
  correctAnswer String
  solution      String
  diagrams      String?      // JSON string of SVG codes
  promptHash    String?      @unique // To avoid duplicates
  
  topicId       String
  topic         Topic        @relation(fields: [topicId], references: [id])
  subtopicId    String?
  subtopic      Subtopic?    @relation(fields: [subtopicId], references: [id])
  
  history       UserHistory[]
  createdAt     DateTime      @default(now())
}

model UserHistory {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  userAnswer String
  isCorrect  Boolean
  timeTaken  Int?     // in seconds
  createdAt  DateTime @default(now())
}
